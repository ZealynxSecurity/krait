{
  "name": "krait",
  "version": "0.1.0",
  "description": "Solidity security audit CLI powered by Claude. 90% precision across 40 blind Code4rena contests.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "krait": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZealynxSecurity/krait.git"
  },
  "homepage": "https://krait.zealynx.io",
  "bugs": {
    "url": "https://github.com/ZealynxSecurity/krait/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "files": [
    "dist",
    "patterns",
    ".claude/commands",
    ".claude/skills",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "security",
    "audit",
    "solidity",
    "smart-contracts",
    "ethereum",
    "defi",
    "ai",
    "claude",
    "claude-code",
    "vulnerability",
    "web3"
  ],
  "author": "Zealynx Security",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "glob": "^11.0.1",
    "js-yaml": "^4.1.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.5",
    "eslint": "^9.21.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
